PORT=8080

# https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# Cascaded modell med explicit språkstöd (rekommenderas för garanterad svenska):
GEMINI_MODEL=gemini-live-2.5-flash
# Alternativ med mer naturlig röst men AUTOMATISK språkdetektering (testa innan ni byter):
# GEMINI_MODEL=gemini-live-2.5-flash-native-audio
GEMINI_VOICE=Aoede

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
TARGET_PHONE_NUMBER=

# Publik HTTPS/WSS-adress dit Twilio kan nå servern.
# Test: ngrok http 8080 -> klistra in https-url:en här.
# Produktion: er Hostinger VPS-domän bakom befintlig nginx/Caddy (TLS redan på plats).
PUBLIC_BASE_URL=https://din-domän-eller-ngrok-url.har
